*{margin:0;padding:0;box-sizing:border-box}
:root{
--navy:#1B2A4A;--navy-mid:#2D4A6A;--navy-light:#3A5F8A;
--copper:#B87333;--copper-light:#D4955A;
--sand:#D4C5A9;--warm-white:#F7F4EF;--charcoal:#3D3D3A;--warm-gray:#8B8880;
--teal:#2D6A5E;--teal-light:#3D8A7A;
--font-display:'DM Serif Display',Georgia,serif;
--font-body:'Instrument Sans','Segoe UI',sans-serif;
}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);color:var(--charcoal);background:var(--warm-white);line-height:1.7;-webkit-font-smoothing:antialiased}

nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(27,42,74,.95);backdrop-filter:blur(12px);padding:0 2rem;height:64px;display:flex;align-items:center;justify-content:space-between}
.nav-mark{font-family:var(--font-display);font-size:1.15rem;color:rgba(255,255,255,.9);text-decoration:none}
.nav-mark span{color:var(--copper)}
.nav-links{display:flex;gap:1.75rem;list-style:none}
.nav-links a{font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,.5);text-decoration:none;transition:color .2s}
.nav-links a:hover,.nav-links a.active{color:var(--copper)}
.nav-cta{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:var(--navy);background:var(--copper);padding:.5rem 1.2rem;border-radius:5px;text-decoration:none;transition:all .2s}
.nav-cta:hover{background:var(--copper-light)}
.menu-btn{display:none;background:none;border:none;cursor:pointer;padding:8px}
.menu-btn span{display:block;width:22px;height:2px;background:white;margin:5px 0}

section{padding:5rem 2rem}
.container{max-width:1000px;margin:0 auto}
.page{display:none}
.page.active{display:block}

/* HERO — navy background */
.hero-section{background:var(--navy);color:white;min-height:92vh;display:flex;align-items:center;padding-top:64px}
.hero-section h1{font-family:var(--font-display);font-size:clamp(2.2rem,4.5vw,3.2rem);color:white;line-height:1.15;margin-bottom:1rem;font-weight:400}
.hero-section p{font-size:1.05rem;color:rgba(255,255,255,.6);max-width:580px;margin-bottom:2rem}
.hero-paths{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-top:2.5rem;max-width:640px}
.hero-path{padding:1.5rem;border:1px solid rgba(255,255,255,.12);border-radius:10px;cursor:pointer;transition:all .25s}
.hero-path:hover{border-color:var(--copper);background:rgba(184,115,51,.06)}
.hero-path h3{font-family:var(--font-display);font-size:1.1rem;color:white;margin-bottom:.35rem;font-weight:400}
.hero-path p{font-size:.85rem;color:rgba(255,255,255,.45);margin:0}
.hero-path .arrow{color:var(--copper);font-size:.8rem;margin-top:.5rem;display:block}

.section-label{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:3px;color:var(--copper);margin-bottom:.75rem}
.section-title{font-family:var(--font-display);font-size:clamp(1.7rem,3.2vw,2.2rem);color:var(--navy);margin-bottom:.75rem;font-weight:400}
.section-intro{font-size:1rem;color:var(--warm-gray);max-width:620px;margin-bottom:2rem}

/* SERVICES */
.service-category{margin-bottom:3rem}
.service-category h3{font-family:var(--font-display);font-size:1.2rem;color:var(--navy);margin-bottom:.5rem;font-weight:400;display:flex;align-items:center;gap:.5rem}
.service-category h3::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--copper);flex-shrink:0}
.service-category>p{font-size:.9rem;color:var(--warm-gray);margin-bottom:1rem;padding-left:1.25rem}
.service-list{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;padding-left:1.25rem}
.service-item{font-size:.85rem;color:var(--charcoal);padding:.6rem .8rem;background:white;border-radius:6px;border:1px solid rgba(212,197,169,.2);transition:border-color .2s}
.service-item:hover{border-color:var(--copper)}

/* VENTURES */
.venture-card{padding:2rem;border:1px solid rgba(212,197,169,.3);border-radius:12px;margin-bottom:1.25rem;background:white}
.venture-status{font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:var(--teal);margin-bottom:.4rem}
.venture-card h3{font-family:var(--font-display);font-size:1.1rem;color:var(--navy);margin-bottom:.4rem;font-weight:400}
.venture-card p{font-size:.88rem;color:var(--warm-gray)}

.venture-thesis{padding:2rem;background:var(--navy);border-radius:12px;color:white;margin:2rem 0}
.venture-thesis h3{font-family:var(--font-display);font-size:1.15rem;color:white;margin-bottom:.75rem;font-weight:400}
.venture-thesis p{font-size:.9rem;color:rgba(255,255,255,.6);margin-bottom:.5rem}
.venture-thesis .thesis-point{padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.08);font-size:.85rem;color:rgba(255,255,255,.5)}

/* PORTFOLIO */
.portfolio-group{margin-bottom:2rem}
.portfolio-group h3{font-family:var(--font-display);font-size:1.1rem;color:var(--navy);margin-bottom:.75rem;font-weight:400;padding-bottom:.4rem;border-bottom:1px solid rgba(212,197,169,.25)}
.portfolio-item{padding:.75rem 0;border-bottom:1px solid rgba(212,197,169,.1)}
.portfolio-item:last-child{border-bottom:none}
.portfolio-item strong{color:var(--navy);font-weight:500;font-size:.9rem}
.portfolio-item p{font-size:.83rem;color:var(--warm-gray);margin-top:.15rem}
.portfolio-item .metric{font-size:.78rem;color:var(--copper);font-weight:500;margin-top:.15rem}

.logo-strip{padding:2.5rem 0;border-top:1px solid rgba(212,197,169,.2);border-bottom:1px solid rgba(212,197,169,.2);margin:2.5rem 0}
.logo-strip p{font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:3px;color:var(--warm-gray);text-align:center;margin-bottom:1.25rem}
.logo-grid{display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:2rem;opacity:.4}
.logo-placeholder{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:var(--navy);padding:.4rem .8rem;border:1px solid rgba(27,42,74,.15);border-radius:3px;white-space:nowrap}

.tech-strip{display:flex;flex-wrap:wrap;gap:.4rem;margin:1rem 0}
.tech-tag{font-size:.68rem;font-weight:500;color:var(--navy-mid);background:rgba(27,42,74,.05);padding:.25rem .6rem;border-radius:3px}

/* DOWNLOADS */
.download-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;margin:1.5rem 0}
.download-card{padding:1.5rem;border:1px solid rgba(212,197,169,.25);border-radius:10px;background:white;transition:border-color .2s}
.download-card:hover{border-color:var(--copper)}
.download-card h4{font-family:var(--font-display);font-size:1rem;color:var(--navy);font-weight:400;margin-bottom:.3rem}
.download-card p{font-size:.8rem;color:var(--warm-gray)}
.download-card .dl-type{font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:var(--copper);margin-top:.5rem}

/* ABOUT */
.about-content{max-width:620px}
.about-content p{margin-bottom:1rem;font-size:.95rem;color:var(--charcoal)}
.about-highlight{font-size:1rem;color:var(--navy);font-weight:500;margin:1.5rem 0;padding-left:1rem;border-left:3px solid var(--copper)}
.kombra-meaning{padding:1.5rem;background:var(--navy);border-radius:10px;color:white;margin:2rem 0}
.kombra-meaning h4{font-family:var(--font-display);font-size:1rem;color:white;margin-bottom:.4rem;font-weight:400}
.kombra-meaning p{font-size:.85rem;color:rgba(255,255,255,.55)}

/* CONTACT */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;margin:1.5rem 0}
.contact-method{margin-bottom:1.25rem}
.contact-method label{font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:var(--warm-gray);display:block;margin-bottom:.2rem}
.contact-method a,.contact-method span{font-size:.95rem;color:var(--navy);text-decoration:none}
.contact-method a:hover{color:var(--copper)}
.intake-form{list-style:none}
.intake-form li{padding:.5rem 0;font-size:.88rem;color:var(--charcoal);display:flex;align-items:center;gap:.5rem}
.intake-form li::before{content:"";width:5px;height:5px;border-radius:50%;background:var(--copper);flex-shrink:0}

footer{background:var(--navy);color:rgba(255,255,255,.4);padding:2.5rem 2rem;text-align:center;font-size:.78rem}
footer a{color:var(--copper-light);text-decoration:none}
footer .footer-name{font-family:var(--font-display);font-size:1rem;color:rgba(255,255,255,.7);margin-bottom:.3rem}

@media(max-width:768px){
  .hero-paths,.service-list,.download-grid,.contact-grid{grid-template-columns:1fr}
  .nav-links{display:none}
  .menu-btn{display:block}
  section{padding:3.5rem 1.25rem}
  .hero-section{min-height:auto;padding-top:90px;padding-bottom:2.5rem}
}
</style>
</head>
