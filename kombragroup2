<script>
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('active'));
  var n=document.getElementById('nav-'+id);if(n)n.classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}
function toggleMenu(){
  var l=document.querySelector('.nav-links');
  var btn=document.querySelector('.menu-btn');
  if(l.classList.contains('open')){
    l.classList.remove('open');
    l.style.display='none';
    btn.classList.remove('open');
  } else {
    l.classList.add('open');
    l.style.display='flex';
    l.style.flexDirection='column';
    l.style.position='absolute';
    l.style.top='100%';
    l.style.left='0';
    l.style.right='0';
    l.style.background='var(--warm-white)';
    l.style.padding='1.5rem';
    l.style.gap='1rem';
    l.style.boxShadow='0 8px 24px rgba(0,0,0,.08)';
    btn.classList.add('open');
  }
}
document.querySelectorAll('.nav-links a').forEach(function(a){
  a.addEventListener('click',function(){
    if(window.innerWidth<768){
      var l=document.querySelector('.nav-links');
      var b=document.querySelector('.menu-btn');
      l.classList.remove('open');
      l.style.display='none';
      b.classList.remove('open');
    }
  });
});
</script>
